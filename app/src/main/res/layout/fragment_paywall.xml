<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:background="#44FFFFFF"
            android:backgroundTint="#44FFFFFF" />

        <!-- ⚡ badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="#FF222222"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:text="⚡ FITALARM PRO"
            android:textColor="#FFD700"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Locked feature label -->
        <TextView
            android:id="@+id/tvLockedFeature"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Unlock this feature with Pro"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Upgrade once, enjoy everything — no limits."
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginBottom="28dp" />

        <!-- Pro features list -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="28dp">

            <include layout="@layout/item_paywall_feature"
                android:id="@+id/feat1" />
            <include layout="@layout/item_paywall_feature"
                android:id="@+id/feat2" />
            <include layout="@layout/item_paywall_feature"
                android:id="@+id/feat3" />
            <include layout="@layout/item_paywall_feature"
                android:id="@+id/feat4" />
            <include layout="@layout/item_paywall_feature"
                android:id="@+id/feat5" />

        </LinearLayout>

        <!-- Price -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="€3.99 / month"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Cancel any time · No commitment"
            android:textColor="#888888"
            android:textSize="12sp"
            android:layout_marginBottom="20dp" />

        <!-- Upgrade button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpgrade"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Upgrade to Pro ⚡"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#FFD700"
            android:textColor="#000000"
            app:cornerRadius="28dp"
            android:layout_marginBottom="12dp" />

        <!-- Restore purchase -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRestore"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restore Purchase"
            android:textColor="#888888"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <!-- Dismiss -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMaybeLater"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Maybe later"
            android:textColor="#555555"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
