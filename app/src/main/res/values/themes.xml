<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.FitAlarm" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorSecondaryVariant">@color/colorSecondaryVariant</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.FitAlarm.Alarm" parent="Theme.FitAlarm">
        <item name="android:windowBackground">@color/alarm_dark_background</item>
        <item name="android:colorBackground">@color/alarm_dark_background</item>
        <item name="android:statusBarColor">@color/alarm_dark_background</item>
        <item name="android:navigationBarColor">@color/alarm_dark_background</item>
    </style>

</resources>
